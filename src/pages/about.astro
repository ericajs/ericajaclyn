---
import Layout from "@/layouts/main.astro"
---
<Layout
  title="About — Erica Jaclyn Stein"
  description="About Erica Jaclyn Stein: digital product designer specializing in agentic design systems and accessibility."
>
  <section class="max-w-6xl mx-auto px-6 py-16 sm:py-24">
    <div class="max-w-2xl space-y-16">

      {/* ── Bio ──────────────────────────────────────────────── */}
      <div class="space-y-4">
        <h1 class="text-2xl sm:text-3xl font-medium tracking-tight">About</h1>
        <p class="text-muted-foreground">
          {/* Replace with your bio — keep it tight, 2–4 sentences max */}
          In progress.
        </p>
      </div>

      {/* ── Approach ─────────────────────────────────────────── */}
      <div class="space-y-6">
        <h2 class="text-xs uppercase tracking-widest text-muted-foreground">Approach</h2>

        <div class="space-y-8">
          <div class="space-y-2">
            <h3 class="font-medium">Accessibility is not a checklist.</h3>
            <p class="text-sm text-muted-foreground">
              {/* Draft your accessibility philosophy here — how it shapes decisions from the start, CPACC context, specific practices */}
              In progress.
            </p>
          </div>

          <div class="space-y-2">
            <h3 class="font-medium">Design systems as shared language.</h3>
            <p class="text-sm text-muted-foreground">
              {/* Draft your design systems philosophy here — how you think about components, tokens, governance, collaboration with eng */}
              In progress.
            </p>
          </div>

          <div class="space-y-2">
            <h3 class="font-medium">Visual work that speaks for itself.</h3>
            <p class="text-sm text-muted-foreground">
              {/* Your editorial philosophy — image-led portfolio, what you choose to show vs. withhold, and why */}
              In progress.
            </p>
          </div>
        </div>
      </div>

      {/* ── Credentials ──────────────────────────────────────── */}
      <div class="space-y-4">
        <h2 class="text-xs uppercase tracking-widest text-muted-foreground">Credentials</h2>
        <ul class="space-y-3 text-sm">
          <li class="flex gap-4">
            <span class="text-muted-foreground shrink-0 w-16">2024</span>
            <span>CPACC — Certified Professional in Accessibility Core Competencies, IAAP</span>
          </li>
          {/* Add additional credentials, education, recognitions here */}
        </ul>
      </div>

      {/* ── Currently ────────────────────────────────────────── */}
      <div class="space-y-4">
        <h2 class="text-xs uppercase tracking-widest text-muted-foreground">Currently</h2>
        <p class="text-sm text-muted-foreground">
          {/* What you're working on, available for, or interested in right now */}
          In progress.
        </p>
      </div>

    </div>
  </section>
</Layout>
