---
import Layout from "@/layouts/main.astro"

// Replace YOUR_FORM_ID with the ID from formspree.io after creating your form
const FORMSPREE_ID = "YOUR_FORM_ID"
const LINKEDIN_URL = "https://www.linkedin.com/in/ericajaclyn/"
---
<Layout
  title="Contact — Erica Jaclyn Stein"
  description="Get in touch with Erica Jaclyn Stein for product design, design systems, and accessible UX work."
>
  <section class="max-w-6xl mx-auto px-6 py-16 sm:py-24">
    <h1 class="text-4xl sm:text-5xl font-medium tracking-tight text-center mb-12 sm:mb-16">Contact</h1>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      {/* ── Left: invitation ──────────────────────────────────── */}
      <div class="lg:py-6">
        <p class="text-sm font-semibold text-muted-foreground mb-3">Connect</p>
        <h2 class="text-2xl sm:text-3xl font-medium tracking-tight">Ready to collaborate?</h2>
        <p class="mt-4 text-muted-foreground max-w-sm">
          I’d love to hear from you! Whether you’re ready to start a project or just want to learn
          more about how I can help, feel free to reach out.
        </p>

        <p class="mt-8 text-sm font-semibold">Contact</p>
        <p class="mt-3 font-medium">Erica Jaclyn Stein</p>
        <p class="text-sm text-muted-foreground">Digital Product Designer</p>

        <a
          href={LINKEDIN_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center justify-center h-9 px-4 rounded-full border border-border text-sm font-semibold hover:bg-accent transition-colors"
        >
          LinkedIn
        </a>
      </div>

      {/* ── Right: form ───────────────────────────────────────── */}
      <div class="bg-muted/50 rounded-2xl p-6 sm:p-10">
        <p class="text-sm font-semibold text-muted-foreground mb-3">Contact</p>
        <h2 class="text-2xl sm:text-3xl font-medium tracking-tight mb-8">Get in touch</h2>

        <form
          id="contact-form"
          action={`https://formspree.io/f/${FORMSPREE_ID}`}
          method="POST"
          novalidate
          class="space-y-6"
        >
          <div>
            <label for="name" class="block text-sm font-medium mb-2">Name</label>
            <input
              id="name" name="name" type="text" required
              autocomplete="name" placeholder="Your Name"
              aria-describedby="name-error"
              class="contact-input w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
            />
            <p id="name-error" data-error class="hidden mt-1.5 text-sm text-destructive">Name is required.</p>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium mb-2">Email</label>
            <input
              id="email" name="email" type="email" required
              autocomplete="email" placeholder="example@gmail.com"
              aria-describedby="email-error"
              class="contact-input w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
            />
            <p id="email-error" data-error class="hidden mt-1.5 text-sm text-destructive">An email address is required.</p>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium mb-2">Message</label>
            <textarea
              id="message" name="message" required rows={5}
              placeholder="Type your message"
              aria-describedby="message-error"
              class="contact-input w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 resize-y"
            ></textarea>
            <p id="message-error" data-error class="hidden mt-1.5 text-sm text-destructive">A brief message is required.</p>
          </div>

          {/* Honeypot */}
          <input type="text" name="_gotcha" class="hidden" aria-hidden="true" tabindex="-1" />

          <div class="flex justify-end">
            <button type="submit" class="pill pill-primary pill-md">Send message</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Error border wins over the base border-input utility */
  .contact-input[aria-invalid="true"] {
    border-color: var(--destructive);
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null
  if (form) {
    const rules: { id: string; empty: string; invalid?: string; check?: (v: string) => boolean }[] = [
      { id: "name", empty: "Name is required." },
      {
        id: "email",
        empty: "An email address is required.",
        invalid: "Please enter a valid email address.",
        check: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v),
      },
      { id: "message", empty: "A brief message is required." },
    ]

    function setError(input: HTMLElement, errorEl: HTMLElement | null, msg: string | null) {
      if (msg) {
        input.classList.add("border-destructive")
        input.setAttribute("aria-invalid", "true")
        if (errorEl) {
          errorEl.textContent = msg
          errorEl.classList.remove("hidden")
        }
      } else {
        input.classList.remove("border-destructive")
        input.removeAttribute("aria-invalid")
        errorEl?.classList.add("hidden")
      }
    }

    form.addEventListener("submit", (e) => {
      let valid = true
      let firstInvalid: HTMLElement | null = null
      for (const r of rules) {
        const input = document.getElementById(r.id) as HTMLInputElement | null
        const errorEl = document.getElementById(`${r.id}-error`)
        if (!input) continue
        const v = input.value.trim()
        let msg: string | null = null
        if (!v) msg = r.empty
        else if (r.check && !r.check(v)) msg = r.invalid ?? r.empty
        setError(input, errorEl, msg)
        if (msg) {
          valid = false
          if (!firstInvalid) firstInvalid = input
        }
      }
      if (!valid) {
        e.preventDefault()
        firstInvalid?.focus()
      }
    })

    // Clear a field's error as the user corrects it
    form.querySelectorAll<HTMLElement>(".contact-input").forEach((input) => {
      input.addEventListener("input", () => {
        const errorEl = document.getElementById(`${input.id}-error`)
        setError(input, errorEl, null)
      })
    })
  }
</script>
