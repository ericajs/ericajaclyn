---
import Layout from "@/layouts/main.astro"

const hero = {
  title: "Astrophotography",
  subtitle: "James Webb Space Telescope NIRCam and MIRI imagery",
  description:
    "These composites begin with the Stage 3 mosaics released through MAST and end with a chain of interpretive choices: filter-to-filter registration, continuum subtraction, non-linear intensity transformations, and the assignment of invisible-wavelength channels to visible color.",
}

type GalleryItem = { name: string; formula?: string; src: string; alt: string }
type Nebula = {
  id: string
  nav: string
  title: string
  subtitle: string
  gallery: GalleryItem[]
  galleryCols: number
  composite?: { src: string; alt: string; caption?: string }
  description: string[]
  meta: [string, string][]
  note?: string
}

const BASE = "/astrophotography"

const nebulae: Nebula[] = [
  {
    id: "carina-stellar-jets",
    nav: "Carina Nebula Stellar Jets",
    title: "Carina Nebula H II Region Stellar Jets",
    subtitle:
      "Uncovering the full spectrum of accretion and outflow in the heart of the Carina Nebula",
    gallery: [
      {
        name: "HE Fe II Emission",
        formula: "F164N − k₂ × F162M",
        src: `${BASE}/5408-CarinaNebula-StellarJets/5408-CN-Stellar-Jets-HH6660-FeII-Emission-Final.jpg`,
        alt: "Continuum-subtracted Fe II emission of HH 666 in the Carina Nebula, rendered orange.",
      },
      {
        name: "H2 Emission",
        formula: "F470N − k₁ × F444W",
        src: `${BASE}/5408-CarinaNebula-StellarJets/5408-CarinaNebula-Stellar-Jets-HH666-H2-Emission-Final.jpg`,
        alt: "Continuum-subtracted molecular hydrogen emission of HH 666, rendered cyan.",
      },
      {
        name: "F470N",
        src: `${BASE}/5408-CarinaNebula-StellarJets/5408-CarinaNebula-Stellar-Jets-HH666-F444W-F470N-BXT-Reg-STR.jpg`,
        alt: "F470N narrowband image of HH 666 after BXT processing.",
      },
    ],
    galleryCols: 3,
    composite: {
      src: `${BASE}/5408-CarinaNebula-StellarJets/5408-CarinaNebula-Stellar-Jets-HH666-Bicolor-FeII-H2.jpg`,
      alt: "Bicolor composite of HH 666 showing Fe II atomic jet in orange and molecular H₂ cocoon in cyan.",
      caption: "Bicolor Fe II + H₂ Emission",
    },
    description: [
      "This image shows a collimated atomic [Fe II] jet at ~10,000 K piercing through a surrounding molecular H₂ cocoon, with the spatial geometry of the embedded protostar's outflow made visible through an orange + cyan emission-line composite.",
      "This is just one of Megan Reiter's six-target survey of the Carina Nebula's Herbig-Haro objects, each with a uniform four-filter NIRCam program. The targets fall under “Molecular Cloud / SFR” with strong H II region overlap.",
    ],
    meta: [
      ["Proposal", "5408"],
      ["Target", "HH 666"],
      ["Release Date", "June 11, 2026"],
      ["Principal Investigator", "Megan Reiter"],
      ["Filters", "F150W2+F164N, F150W2+F162M, F444W+F470N, F444W"],
    ],
  },
  {
    id: "cats-paw",
    nav: "Cat's Paw Nebula",
    title: "Cat's Paw Nebula",
    subtitle: "NIRCam Observations of a Star-Forming Nebula",
    gallery: [
      { name: "F187N", src: `${BASE}/6778-CatsPawNebula-SFReg1/6778-CatsPawNebula-SFReg1-F187N-Color.jpg`, alt: "F187N narrowband channel of the Cat's Paw Nebula." },
      { name: "F200W", src: `${BASE}/6778-CatsPawNebula-SFReg1/6778-CatsPawNebula-SFReg1-F200W-Color.jpg`, alt: "F200W broadband channel of the Cat's Paw Nebula." },
      { name: "F277W", src: `${BASE}/6778-CatsPawNebula-SFReg1/6778-CatsPawNebula-SFReg1-F277W-Color.jpg`, alt: "F277W broadband channel of the Cat's Paw Nebula." },
      { name: "F356M", src: `${BASE}/6778-CatsPawNebula-SFReg1/6778-CatsPawNebula-SFReg1-F356M-Color.jpg`, alt: "F356M medium-band channel of the Cat's Paw Nebula." },
      { name: "F470N", src: `${BASE}/6778-CatsPawNebula-SFReg1/6778-CatsPawNebula-SFReg1-F470N-Color.jpg`, alt: "F470N narrowband channel of the Cat's Paw Nebula." },
    ],
    galleryCols: 5,
    composite: {
      src: `${BASE}/6778-CatsPawNebula-SFReg1/6778-CatsPawNebula-SFreg1-Final.jpg`,
      alt: "Final color composite of a star-forming region in the Cat's Paw Nebula (NGC 6334).",
    },
    description: [
      "Proposal 6778 is a Director's Discretionary (DD) program led by Macarena García Marín (STScI), executed in a single visit, and it is the source dataset for the JWST third-anniversary public release of the Cat's Paw Nebula.",
    ],
    meta: [
      ["Proposal", "6778"],
      ["Target", "NGC 6334"],
      ["Release Date", "July 10, 2025"],
      ["Principal Investigator", "Macarena García Marín"],
      ["Filters", "F187N, F200W, F277W, F356M, F470N"],
    ],
  },
  {
    id: "southern-ring",
    nav: "Southern Ring Nebula",
    title: "Southern Ring Nebula",
    subtitle: "JWST Early Release Observation 7",
    gallery: [
      { name: "F090W", src: `${BASE}/2733-SouthernRingNebula-NGC3132/2733-SouthernRingNebula-NGC3132-F090W-Color.jpg`, alt: "F090W broadband channel of the Southern Ring Nebula." },
      { name: "F187N", src: `${BASE}/2733-SouthernRingNebula-NGC3132/2733-SouthernRingNebula-NGC3132-F187N-Color.jpg`, alt: "F187N narrowband channel of the Southern Ring Nebula." },
      { name: "F212N", src: `${BASE}/2733-SouthernRingNebula-NGC3132/2733-SouthernRingNebula-NGC3132-F212N-Color.jpg`, alt: "F212N narrowband channel of the Southern Ring Nebula." },
      { name: "F356W", src: `${BASE}/2733-SouthernRingNebula-NGC3132/2733-SouthernRingNebula-NGC3132-F356W-Color.jpg`, alt: "F356W broadband channel of the Southern Ring Nebula." },
      { name: "F405N", src: `${BASE}/2733-SouthernRingNebula-NGC3132/2733-SouthernRingNebula-NGC3132-F405N-Color.jpg`, alt: "F405N narrowband channel of the Southern Ring Nebula." },
      { name: "F470N", src: `${BASE}/2733-SouthernRingNebula-NGC3132/2733-SouthernRingNebula-NGC3132-F470N-Color.jpg`, alt: "F470N narrowband channel of the Southern Ring Nebula." },
    ],
    galleryCols: 6,
    composite: {
      src: `${BASE}/2733-SouthernRingNebula-NGC3132/2733-SouthernRingNebula-NGC3132-Final.jpg`,
      alt: "Final color composite of the Southern Ring Nebula (NGC 3132).",
    },
    description: [
      "The Southern Ring Nebula observations were part of the JWST's Early Release Observations (ERO) program—the telescope's first public science showcase and one of several flagship ERO targets.",
      "It's a planetary nebula: the glowing, expelled envelope of a dying star. JWST's big payoff was the central star system — the infrared view showed that the star actually shaping the nebula is a faint white dwarf, nearly lost in the glare of its brighter companion, ringed by spiral structure and a dusty disk that point to a multiple-star history (De Marco et al. 2022). The six NIRCam filters separate the ionized gas, the molecular halo, the dust, and the stars, mapping how the dying star shed its mass over time.",
    ],
    meta: [
      ["Proposal", "2733"],
      ["Target", "NGC 3132"],
      ["Release Date", "July 12, 2022"],
      ["Principal Investigator", "Klaus Pontoppidan"],
      ["Filters", "F090W, F187N, F212N, F356W, F405N, F470N"],
    ],
  },
  {
    id: "cosmic-cliffs",
    nav: "Carina Nebula Cosmic Cliffs",
    title: "Cosmic Cliffs of the Carina Nebula",
    subtitle: "JWST Early Release Observation 5",
    gallery: [
      { name: "F090W", src: `${BASE}/2731-CarinaNebula-Cliffs-NGC3324/2731-CarinaNebula-Cliffs-F090W-Color.jpg`, alt: "F090W broadband channel of the Cosmic Cliffs in the Carina Nebula." },
      { name: "F187N", src: `${BASE}/2731-CarinaNebula-Cliffs-NGC3324/2731-CarinaNebula-Cliffs-F187N-Color.jpg`, alt: "F187N narrowband channel of the Cosmic Cliffs." },
      { name: "F200W", src: `${BASE}/2731-CarinaNebula-Cliffs-NGC3324/2731-CarinaNebula-Cliffs-F200W-Color.jpg`, alt: "F200W broadband channel of the Cosmic Cliffs." },
      { name: "F335M", src: `${BASE}/2731-CarinaNebula-Cliffs-NGC3324/2731-CarinaNebula-Cliffs-F335M-Color.jpg`, alt: "F335M medium-band channel of the Cosmic Cliffs." },
      { name: "F444W", src: `${BASE}/2731-CarinaNebula-Cliffs-NGC3324/2731-CarinaNebula-Cliffs-F444W-Color.jpg`, alt: "F444W broadband channel of the Cosmic Cliffs." },
    ],
    galleryCols: 5,
    composite: {
      src: `${BASE}/2731-CarinaNebula-Cliffs-NGC3324/2731-CarinaNebula-Cliffs-NGC3324-Final.jpg`,
      alt: "Final color composite of the Cosmic Cliffs region (NGC 3324) of the Carina Nebula.",
    },
    description: ["Description coming soon."],
    meta: [
      ["Proposal", "2731"],
      ["Target", "NGC 3324"],
      ["Filters", "F090W, F187N, F200W, F335M, F444W"],
    ],
  },
  {
    id: "pillars-of-creation",
    nav: "Pillars of Creation",
    title: "Pillars of Creation",
    subtitle: "Eagle Nebula (M16)",
    gallery: [
      { name: "F090W", src: `${BASE}/2739-PillarsOfCreation-EagleNebula-M16/2739-PillarsOfCreation-EagleNebula-M16-F090W-Color.jpg`, alt: "F090W broadband channel of the Pillars of Creation." },
      { name: "F187N", src: `${BASE}/2739-PillarsOfCreation-EagleNebula-M16/2739-PillarsOfCreation-EagleNebula-M16-F187N-Color.jpg`, alt: "F187N narrowband channel of the Pillars of Creation." },
      { name: "F200W", src: `${BASE}/2739-PillarsOfCreation-EagleNebula-M16/2739-PillarsOfCreation-EagleNebula-M16-F200W-Color.jpg`, alt: "F200W broadband channel of the Pillars of Creation." },
      { name: "F335M", src: `${BASE}/2739-PillarsOfCreation-EagleNebula-M16/2739-PillarsOfCreation-EagleNebula-M16-F335M-Color.jpg`, alt: "F335M medium-band channel of the Pillars of Creation." },
      { name: "F444W", src: `${BASE}/2739-PillarsOfCreation-EagleNebula-M16/2739-PillarsOfCreation-EagleNebula-M16-F444W-Color.jpg`, alt: "F444W broadband channel of the Pillars of Creation." },
    ],
    galleryCols: 5,
    composite: {
      src: `${BASE}/2739-PillarsOfCreation-EagleNebula-M16/2739-PillarsOfCreation-EagleNebula-M16-Final.jpg`,
      alt: "Final color composite of the Pillars of Creation in the Eagle Nebula (M16).",
    },
    description: ["Description coming soon."],
    meta: [
      ["Proposal", "2739"],
      ["Target", "Eagle Nebula (M16)"],
      ["Filters", "F090W, F187N, F200W, F335M, F444W"],
    ],
  },
]

// Responsive grid class for the channel gallery based on desktop column count
const galleryGrid = (cols: number) => {
  if (cols <= 3) return "grid grid-cols-1 sm:grid-cols-3 gap-3"
  if (cols <= 5) return "grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3"
  return "grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-3"
}

const aboutLead =
  "Unlike local astrophotography data, JWST i2d.fits data is already calibrated, dark-subtracted, flat-fielded, and mostly distortion-corrected. My job is alignment, dynamic range control, noise management, flux normalization, color mapping, calibration, and detail enhancement."

const acknowledgments = [
  "Some/all of the data presented here were obtained from the Mikulski Archive for Space Telescopes (MAST). STScI is operated by the Association of Universities for Research in Astronomy, Inc., under NASA contract NAS5-26555. Support for MAST for non-HST data is provided by the NASA Office of Space Science via grant NNX13AC07G and by other grants and contracts.",
  "James Webb Space Telescope data courtesy of NASA/JPL, ESA, CSA, STScI.",
]
---
<Layout
  title="Astrophotography — Erica Jaclyn Stein"
  description="JWST NIRCam and MIRI image processing by Erica Jaclyn Stein — public data, artistically rendered."
>
  <section class="max-w-6xl mx-auto px-6 py-16 sm:py-24">

    {/* ── Hero ──────────────────────────────────────────────── */}
    <div class="text-center max-w-2xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-medium tracking-tight">{hero.title}</h1>
      <p class="mt-4 text-lg text-muted-foreground">{hero.subtitle}</p>
    </div>

    <div class="mt-12 grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <p class="text-muted-foreground leading-relaxed">{hero.description}</p>
      <nav aria-label="Jump to image" class="bg-muted/50 rounded-2xl p-6 sm:p-8">
        <p class="text-sm font-semibold text-muted-foreground mb-4">Jump to</p>
        <ul class="space-y-3">
          {nebulae.map((n) => (
            <li>
              <a href={`#${n.id}`} class="text-sm font-medium hover:underline underline-offset-4">
                {n.nav}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    {/* ── Nebula sections ───────────────────────────────────── */}
    <div class="mt-20 sm:mt-28 space-y-24 sm:space-y-32">
      {nebulae.map((n, idx) => (
        <section id={n.id} class="scroll-mt-24">
          <header class="text-center max-w-2xl mx-auto mb-8">
            <h2 class="text-2xl sm:text-3xl font-medium tracking-tight">{n.title}</h2>
            {n.subtitle && <p class="mt-3 text-muted-foreground">{n.subtitle}</p>}
          </header>

          {/* Channel gallery — landscape tiles with overlaid captions */}
          {n.gallery.length > 0 && (
            <ul class:list={[galleryGrid(n.galleryCols), "mb-4", idx === 0 && "hero-gallery"]}>
              {n.gallery.map((g) => (
                <li>
                  <button
                    type="button"
                    class="lightbox-trigger relative block w-full aspect-video rounded-md overflow-hidden border border-border bg-neutral-900 cursor-zoom-in focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                    data-src={g.src}
                    data-alt={g.alt}
                    data-title={g.name}
                    data-subtitle={g.formula ?? ""}
                    aria-label={`View ${g.name}${g.formula ? " — " + g.formula : ""} full screen`}
                  >
                    <img
                      src={g.src}
                      alt={g.alt}
                      loading="lazy"
                      decoding="async"
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                    <div class="absolute bottom-3 left-3 right-3 text-white text-left pointer-events-none">
                      <p class="text-sm font-semibold leading-none">{g.name}</p>
                      {g.formula && <p class="text-xs mt-1.5 text-white/80">{g.formula}</p>}
                    </div>
                  </button>
                </li>
              ))}
            </ul>
          )}

          {/* Composite image + centered caption */}
          {n.composite && (
            <figure class="m-0">
              <button
                type="button"
                class="lightbox-trigger block w-full cursor-zoom-in focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-md"
                data-src={n.composite.src}
                data-alt={n.composite.alt}
                data-title={n.title}
                data-subtitle={n.composite.caption ?? ""}
                aria-label={`View ${n.title} composite full screen`}
              >
                <img
                  src={n.composite.src}
                  alt={n.composite.alt}
                  loading={idx === 0 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={idx === 0 ? "high" : "auto"}
                  class="w-full h-auto rounded-md border border-border bg-neutral-900"
                />
              </button>
              {n.composite.caption && (
                <figcaption class="mt-3 text-center text-sm font-medium">{n.composite.caption}</figcaption>
              )}
            </figure>
          )}

          {/* Metadata (left) + description (right) — Data First */}
          {n.note ? (
            <p class="mt-8 text-sm text-muted-foreground italic text-center">{n.note}</p>
          ) : (
            <div class="mt-12 grid md:grid-cols-2 gap-8 lg:gap-12 items-stretch">
              <dl class="text-sm self-center">
                {n.meta.map(([label, value]) => (
                  <div class="flex gap-4 justify-between items-start border-b border-border py-3">
                    <dt class="font-semibold text-muted-foreground whitespace-nowrap">{label}</dt>
                    <dd class="text-right">{value}</dd>
                  </div>
                ))}
              </dl>
              <div class="bg-muted/50 rounded-2xl p-6 sm:p-10 flex flex-col justify-center">
                <div class="space-y-4 leading-relaxed">
                  {n.description.map((p) => <p>{p}</p>)}
                </div>
              </div>
            </div>
          )}
        </section>
      ))}
    </div>

    {/* ── About ─────────────────────────────────────────────── */}
    <div class="mt-28 sm:mt-36 max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-medium tracking-tight">About</h2>
    </div>
    <div class="mt-10 max-w-3xl mx-auto space-y-5 leading-relaxed">
      <p>{aboutLead}</p>
      <p>
        All images are public data, processed through multiple applications, and artistically
        rendered by Erica Jaclyn Stein. Full res options for print and display available. Please
        send requests to <a href="mailto:erica@ericajaclyn.com" class="underline underline-offset-4 hover:opacity-70 transition-opacity">erica@ericajaclyn.com</a>.
      </p>
    </div>

    {/* Acknowledgments accordion (collapsed by default) */}
    <div class="mt-10 max-w-3xl mx-auto border-t border-border">
      <details class="group border-b border-border">
        <summary class="flex items-center justify-between py-5 cursor-pointer list-none">
          <span class="text-base font-medium">Acknowledgments</span>
          <span class="relative size-5 shrink-0 text-muted-foreground" aria-hidden="true">
            <svg class="absolute inset-0 group-open:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <svg class="absolute inset-0 hidden group-open:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </span>
        </summary>
        <div class="pb-6 space-y-3 text-sm text-muted-foreground leading-relaxed">
          {acknowledgments.map((a) => <p>{a}</p>)}
        </div>
      </details>
    </div>

    {/* ── View Work CTA ─────────────────────────────────────── */}
    <div class="mt-16 text-center">
      <a href="/uxdesign" class="pill pill-primary pill-md">View Work</a>
    </div>
  </section>

  {/* ── Lightbox overlay ────────────────────────────────────── */}
  <div
    id="lightbox"
    class="lightbox fixed inset-0 z-50 hidden bg-black/95 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
  >
    <button
      type="button"
      id="lightbox-close"
      aria-label="Close viewer"
      class="absolute z-10 top-4 right-4 sm:top-6 sm:right-6 flex items-center justify-center size-11 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <button
      type="button"
      id="lightbox-prev"
      aria-label="Previous image"
      class="absolute z-10 left-4 sm:left-6 top-1/2 -translate-y-1/2 flex items-center justify-center size-11 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    </button>

    <button
      type="button"
      id="lightbox-next"
      aria-label="Next image"
      class="absolute z-10 right-4 sm:right-6 top-1/2 -translate-y-1/2 flex items-center justify-center size-11 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </button>

    <figure class="absolute inset-0 flex flex-col items-center justify-center px-4 sm:px-20 py-16 sm:py-20 m-0">
      <img id="lightbox-img" alt="" class="max-w-full max-h-[80vh] object-contain" />
      <figcaption class="mt-6 text-center text-white max-w-2xl">
        <p id="lightbox-title" class="text-base sm:text-lg font-semibold"></p>
        <p id="lightbox-subtitle" class="mt-1 text-sm text-white/70"></p>
      </figcaption>
    </figure>
  </div>
</Layout>

<style>
  /* ── Wave bounce-in for the first section's channel gallery ── */
  .hero-gallery > li {
    opacity: 0;
    animation: hero-wave-in 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .hero-gallery > li:nth-child(1) { animation-delay: 0.15s; }
  .hero-gallery > li:nth-child(2) { animation-delay: 0.30s; }
  .hero-gallery > li:nth-child(3) { animation-delay: 0.45s; }
  .hero-gallery > li:nth-child(4) { animation-delay: 0.60s; }
  .hero-gallery > li:nth-child(5) { animation-delay: 0.75s; }
  .hero-gallery > li:nth-child(6) { animation-delay: 0.90s; }

  @keyframes hero-wave-in {
    0%   { opacity: 0; transform: translateY(24px) scale(0.94); }
    60%  { opacity: 1; transform: translateY(-8px) scale(1.02); }
    100% { opacity: 1; transform: translateY(0)    scale(1);    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-gallery > li {
      opacity: 1;
      animation: none;
    }
  }

  /* Lightbox open state — flex layout activated when .is-open is toggled */
  .lightbox.is-open { display: block; }
</style>

<script>
  const lightbox = document.getElementById("lightbox")
  const imgEl = document.getElementById("lightbox-img") as HTMLImageElement | null
  const titleEl = document.getElementById("lightbox-title")
  const subtitleEl = document.getElementById("lightbox-subtitle")
  const closeBtn = document.getElementById("lightbox-close")
  const prevBtn = document.getElementById("lightbox-prev")
  const nextBtn = document.getElementById("lightbox-next")

  const triggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".lightbox-trigger")
  )

  let currentIndex = 0
  let lastFocus: HTMLElement | null = null

  function render(idx: number) {
    const t = triggers[idx]
    if (!t || !imgEl || !titleEl || !subtitleEl) return
    imgEl.src = t.dataset.src ?? ""
    imgEl.alt = t.dataset.alt ?? ""
    titleEl.textContent = t.dataset.title ?? ""
    subtitleEl.textContent = t.dataset.subtitle ?? ""
    subtitleEl.style.display = t.dataset.subtitle ? "" : "none"
    currentIndex = idx
  }

  function open(idx: number) {
    if (!lightbox) return
    lastFocus = document.activeElement as HTMLElement
    render(idx)
    lightbox.classList.add("is-open")
    lightbox.classList.remove("hidden")
    document.documentElement.style.overflow = "hidden"
    document.addEventListener("keydown", onKeydown)
    closeBtn?.focus()
  }

  function close() {
    if (!lightbox) return
    lightbox.classList.remove("is-open")
    lightbox.classList.add("hidden")
    document.documentElement.style.overflow = ""
    document.removeEventListener("keydown", onKeydown)
    lastFocus?.focus()
  }

  function step(delta: number) {
    if (!triggers.length) return
    render((currentIndex + delta + triggers.length) % triggers.length)
  }

  function onKeydown(e: KeyboardEvent) {
    if (e.key === "Escape") { close(); return }
    if (e.key === "ArrowLeft")  { e.preventDefault(); step(-1) }
    if (e.key === "ArrowRight") { e.preventDefault(); step(+1) }
  }

  triggers.forEach((t, i) => t.addEventListener("click", () => open(i)))
  closeBtn?.addEventListener("click", close)
  prevBtn?.addEventListener("click", () => step(-1))
  nextBtn?.addEventListener("click", () => step(+1))
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) close()
  })
</script>
