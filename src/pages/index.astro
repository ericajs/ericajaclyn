---
import { getCollection } from "astro:content"
import Layout from "@/layouts/main.astro"

const allWork = await getCollection("work")
const featured = allWork
  .filter((e) => e.data.treatment === "full")
  .sort((a, b) => a.data.order - b.data.order)

const slides = featured.map((e) => ({
  id: e.id,
  title: e.data.title,
  scope: e.data.scope,
  cover: e.data.coverImage ?? "",
  alt: e.data.coverAlt ?? "",
}))
const first = slides[0]
---
<Layout>
  <section class="grid lg:grid-cols-[2fr_3fr] min-h-[600px] lg:min-h-[calc(100svh-66px)]">

    {/* ── Left dark panel ─────────────────────────────────────── */}
    <div class="bg-[#0e0e0f] text-white flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-16 text-center lg:text-left">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-[1.05]">
        Digital Product Design
      </h1>
      <p class="mt-6 text-white/70 max-w-md mx-auto lg:mx-0">
        Accessible and Inclusive User Experiences, Adaptive Design Systems, Agentic Automation
      </p>
      <div class="mt-8 flex flex-col items-center lg:items-start gap-4">
        <a href="/uxdesign" class="pill pill-md bg-white text-neutral-900 hover:opacity-90">
          View work
        </a>
        <a href="/contact" class="text-sm font-medium underline underline-offset-4 hover:opacity-70 transition-opacity">
          Get in touch
        </a>
      </div>
    </div>

    {/* ── Right featured image + pagination ───────────────────── */}
    <div class="flex flex-col min-h-[360px] lg:min-h-0">
      <div class="relative flex-1 bg-muted overflow-hidden">
        {slides.map((s, i) => (
          <div class="hero-slide absolute inset-0" data-slide={i} style={i === 0 ? "" : "display:none"}>
            {s.cover ? (
              <img src={s.cover} alt={s.alt} class="h-full w-full object-cover" />
            ) : (
              <div class="h-full w-full flex items-center justify-center bg-muted">
                <span class="text-muted-foreground text-sm uppercase tracking-widest">{s.title}</span>
              </div>
            )}
          </div>
        ))}
      </div>

      {/* Pagination bar */}
      <div class="flex items-center justify-between gap-4 px-6 py-4 text-sm border-t border-border">
        <div class="flex items-center gap-3 min-w-0">
          <span id="hero-count" class="text-muted-foreground shrink-0">1 of {slides.length}</span>
          <a id="hero-link" href={`/uxdesign/${first.id}`} class="font-medium underline underline-offset-4 truncate">
            {first.title}
          </a>
          <span id="hero-scope" class="text-muted-foreground hidden sm:inline truncate">{first.scope}</span>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <button id="hero-prev" type="button" aria-label="Previous project" class="flex items-center justify-center size-9 rounded-md hover:bg-accent transition-colors cursor-pointer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <button id="hero-next" type="button" aria-label="Next project" class="flex items-center justify-center size-9 rounded-md hover:bg-accent transition-colors cursor-pointer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ slides }}>
  const els = Array.from(document.querySelectorAll(".hero-slide"))
  const countEl = document.getElementById("hero-count")
  const linkEl = document.getElementById("hero-link")
  const scopeEl = document.getElementById("hero-scope")
  let i = 0

  function show(n) {
    i = (n + slides.length) % slides.length
    els.forEach((el, idx) => (el.style.display = idx === i ? "" : "none"))
    if (countEl) countEl.textContent = `${i + 1} of ${slides.length}`
    if (linkEl) {
      linkEl.textContent = slides[i].title
      linkEl.setAttribute("href", `/uxdesign/${slides[i].id}`)
    }
    if (scopeEl) scopeEl.textContent = slides[i].scope
  }

  document.getElementById("hero-prev")?.addEventListener("click", () => show(i - 1))
  document.getElementById("hero-next")?.addEventListener("click", () => show(i + 1))
</script>
