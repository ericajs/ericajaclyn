---
interface Props {
  class?: string
}
const { class: className = "" } = Astro.props
---
<div
  class:list={["inline-flex items-center gap-0.5 h-9 p-0.5 rounded-full border border-border", className]}
  role="group"
  aria-label="Color theme"
>
  <button
    type="button"
    data-theme-set="dark"
    aria-label="Dark mode"
    aria-pressed="false"
    class="theme-seg flex-1 flex items-center justify-center h-full px-3 rounded-full transition-colors hover:bg-accent/60 cursor-pointer"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
      <path d="M19 3v4" />
      <path d="M21 5h-4" />
    </svg>
  </button>
  <button
    type="button"
    data-theme-set="light"
    aria-label="Light mode"
    aria-pressed="false"
    class="theme-seg flex-1 flex items-center justify-center h-full px-3 rounded-full transition-colors hover:bg-accent/60 cursor-pointer"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2" /><path d="M12 20v2" /><path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" />
      <path d="M2 12h2" /><path d="M20 12h2" /><path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" />
    </svg>
  </button>
</div>
