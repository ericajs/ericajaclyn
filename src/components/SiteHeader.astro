---
import Logo from "@/components/Logo.astro"

const leftNav = [
  { href: "/uxdesign", label: "UX Design" },
  { href: "/astrophotography", label: "Astrophotography" },
]
const rightNav = [
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
]

const currentPath = Astro.url.pathname
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href)
---
<header class="border-b border-border">
  <div class="mx-auto max-w-[1920px] px-6 py-4">

    {/* Desktop — centered logo, pills left & right */}
    <div class="hidden md:grid grid-cols-3 items-center">
      <nav aria-label="Primary" class="flex items-center gap-1 justify-self-start">
        {leftNav.map(({ href, label }) => (
          <a
            href={href}
            aria-current={isActive(href) ? "page" : undefined}
            class:list={["pill pill-ghost pill-md", isActive(href) && "bg-accent"]}
          >
            {label}
          </a>
        ))}
      </nav>

      <a href="/" class="justify-self-center hover:opacity-70 transition-opacity" aria-label="Home">
        <Logo class="size-8" />
      </a>

      <nav aria-label="Secondary" class="flex items-center gap-1 justify-self-end">
        {rightNav.map(({ href, label }) => (
          <a
            href={href}
            aria-current={isActive(href) ? "page" : undefined}
            class:list={["pill pill-ghost pill-md", isActive(href) && "bg-accent"]}
          >
            {label}
          </a>
        ))}
      </nav>
    </div>

    {/* Mobile — logo + hamburger */}
    <div class="flex md:hidden items-center justify-between">
      <a href="/" class="hover:opacity-70 transition-opacity" aria-label="Home">
        <Logo class="size-8" />
      </a>
      <button
        type="button"
        id="menu-open"
        aria-label="Open menu"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="flex items-center justify-center size-9 rounded-md hover:bg-accent transition-colors cursor-pointer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</header>

{/* ── Mobile menu overlay ─────────────────────────────────────── */}
<div
  id="mobile-menu"
  class="mobile-overlay md:hidden fixed inset-0 z-50 bg-background/35 backdrop-blur-2xl"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
>
  <div class="panel bg-background border-b border-border">
    <div class="mx-auto max-w-[1920px] px-6 py-4">
      <div class="flex items-center justify-between">
        <a href="/" class="hover:opacity-70 transition-opacity" aria-label="Home">
          <Logo class="size-8" />
        </a>
        <button
          type="button"
          id="menu-close"
          aria-label="Close menu"
          class="flex items-center justify-center size-9 rounded-md hover:bg-accent transition-colors cursor-pointer"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>

      <nav aria-label="Mobile" class="mt-6 flex flex-col items-center gap-5 pb-2">
        <div class="flex flex-col items-center gap-1 w-full">
          {leftNav.map(({ href, label }) => (
            <a
              href={href}
              aria-current={isActive(href) ? "page" : undefined}
              class:list={["py-2 text-base font-semibold hover:opacity-70 transition-opacity", isActive(href) && "underline underline-offset-4"]}
            >
              {label}
            </a>
          ))}
        </div>
        <hr class="w-full border-t border-border" />
        <div class="flex flex-col items-center gap-1 w-full">
          {rightNav.map(({ href, label }) => (
            <a
              href={href}
              aria-current={isActive(href) ? "page" : undefined}
              class:list={["py-2 text-base font-semibold hover:opacity-70 transition-opacity", isActive(href) && "underline underline-offset-4"]}
            >
              {label}
            </a>
          ))}
        </div>
      </nav>
    </div>
  </div>
</div>

<style>
  .mobile-overlay {
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .mobile-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }
  .mobile-overlay .panel {
    transform: translateY(-14px);
    opacity: 0;
    transition:
      transform 0.34s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.22s ease;
  }
  .mobile-overlay.is-open .panel {
    transform: translateY(0);
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-overlay,
    .mobile-overlay .panel {
      transition-duration: 0.01ms;
    }
    .mobile-overlay .panel {
      transform: none;
    }
  }
</style>

<script>
  const overlay = document.getElementById("mobile-menu")
  const openBtn = document.getElementById("menu-open")
  const closeBtn = document.getElementById("menu-close")

  if (overlay && openBtn && closeBtn) {
    const focusable = () =>
      Array.from(overlay.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'))

    function open() {
      overlay!.classList.add("is-open")
      openBtn!.setAttribute("aria-expanded", "true")
      document.documentElement.style.overflow = "hidden"
      closeBtn!.focus()
      document.addEventListener("keydown", onKeydown)
    }
    function close() {
      overlay!.classList.remove("is-open")
      openBtn!.setAttribute("aria-expanded", "false")
      document.documentElement.style.overflow = ""
      document.removeEventListener("keydown", onKeydown)
      openBtn!.focus()
    }
    function onKeydown(e: KeyboardEvent) {
      if (e.key === "Escape") return close()
      if (e.key === "Tab") {
        const items = focusable()
        if (!items.length) return
        const first = items[0], last = items[items.length - 1]
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault(); last.focus()
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault(); first.focus()
        }
      }
    }

    openBtn.addEventListener("click", open)
    closeBtn.addEventListener("click", close)
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) close()
    })
    focusable().forEach((el) => {
      if (el.tagName === "A") el.addEventListener("click", close)
    })
  }
</script>
