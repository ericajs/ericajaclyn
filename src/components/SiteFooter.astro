---
import Logo from "@/components/Logo.astro"

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/uxdesign", label: "UX Design" },
  { href: "/astrophotography", label: "Astrophotography" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
]
const socials = [
  { href: "https://www.linkedin.com/in/ericajaclyn/", label: "LinkedIn" },
  { href: "https://www.behance.net/ericajaclyn", label: "Behance" },
]
const year = new Date().getFullYear()
---
<footer>
  <div class="mx-auto max-w-[1920px] px-6 py-16 sm:py-24 flex flex-col gap-12">
    <hr class="border-t border-border" />

    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      {/* Nav links */}
      <nav aria-label="Footer" class="flex flex-col items-start gap-0 md:flex-1">
        {navLinks.map(({ href, label }) => (
          <a href={href} class="pill pill-ghost pill-sm">{label}</a>
        ))}
      </nav>

      {/* Logo */}
      <div class="md:flex-1 flex justify-start md:justify-center">
        <a href="/" class="hover:opacity-70 transition-opacity" aria-label="Home">
          <Logo class="size-8" />
        </a>
      </div>

      {/* Socials */}
      <nav aria-label="Social" class="flex flex-col items-start md:items-end gap-0 md:flex-1">
        {socials.map(({ href, label }) => (
          <a href={href} target="_blank" rel="noopener noreferrer" class="pill pill-ghost pill-sm">{label}</a>
        ))}
      </nav>
    </div>

    <p class="text-xs text-muted-foreground">Copyright © {year} ericajaclyn.com</p>
  </div>
</footer>
